# Tessera environment variables. Copy to .env.local and fill in.
# See design/TDD.md §11.3 for which values to use in each env.

# JWT signing secret (used to sign our session JWTs). Independent from
# Supabase's JWT secret — see TDD §5.3.
# Generate with: openssl rand -base64 32
TESSERA_JWT_SECRET=

# Public URL of this deployment (used in host-recovery URLs).
# - local:   http://localhost:3000
# - preview: https://<your-preview>.vercel.app
# - prod:    https://tessera.app
TESSERA_PUBLIC_URL=http://localhost:3000

# Supabase — your project URL + keys (Settings → API in the dashboard).
# Anon key is RLS-protected and safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key bypasses RLS. Server-only; never bundled into the client.
SUPABASE_SERVICE_ROLE_KEY=

# AI brief generation. The runtime router (lib/briefs/router.ts) tries
# OpenAI first (more reliable quota at workshop scale), then Gemini
# (free fallback), then the static brief library. Both keys are
# optional — if both are unset every "AI-generated" brief is silently
# library-sourced. Setting at least one keeps the AI path live;
# setting both buys redundancy when one provider is rate-limited or
# down. Server-only — never bundled into the client.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Google OAuth client for the per-pair Meet breakouts feature. Set
# both values to enable. The OAuth flow (built on `arctic`) asks the
# GM for the `calendar.events` scope; Tessera mints one short
# calendar event per pair via the Calendar API and uses the
# auto-attached Meet link as the pair's breakout call. Events are
# anchored 1 hour in the past, private visibility, deleted
# automatically when the GM ends the game. Tokens are AES-256-GCM
# encrypted at rest in `gm_google_tokens`. Server-only — the client
# never sees these.
#
# Setup:
#   1. Google Cloud Console → APIs & Services → Enable "Google
#      Calendar API".
#   2. APIs & Services → OAuth consent screen → External, add the
#      `.../auth/calendar.events` scope.
#   3. APIs & Services → Credentials → Create OAuth client (Web app).
#      Authorized redirect URI: <TESSERA_PUBLIC_URL>/api/auth/google/callback
#      (when running locally also add http://localhost:3000/api/auth/google/callback)
#   4. Paste the client id / secret here.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
