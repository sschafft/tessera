# Tessera environment variables. Copy to .env.local and fill in.
# See design/TDD.md §11.3 for which values to use in each env.

# JWT signing secret (must match the Supabase project's JWT secret).
# Generate with: openssl rand -base64 32
TESSERA_JWT_SECRET=

# Public URL of this deployment (used in host-recovery URLs).
# - local:   http://localhost:3000
# - preview: https://<your-preview>.vercel.app
# - prod:    https://tessera.app
TESSERA_PUBLIC_URL=http://localhost:3000

# Supabase — fill these in once a tessera-dev project exists.
# Leave blank during initial frontend skeleton; the app falls back to an
# in-memory store. Once these are set the repository layer switches to
# Supabase automatically.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — leave blank for local development. The app falls back to the
# library brief source when this is unset. Set in Vercel Production only.
GEMINI_API_KEY=
