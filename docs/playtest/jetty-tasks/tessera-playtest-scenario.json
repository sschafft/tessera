{
  "name": "tessera-playtest-scenario",
  "description": "Runs a Codex agent through one Tessera playtest scenario across multiple role tabs and reports findings as JSON. The DIY orchestrator (docs/playtest/run-orchestrator.sh) fans out to this task once per role with a pre-rendered instruction in init_params.instruction.",
  "workflow": {
    "init_params": {
      "instruction": "(passed at run time)"
    },
    "step_configs": {
      "play": {
        "activity": "runbook",
        "agent": "codex",
        "model": "gpt-5.4",
        "instruction_path": "init_params.instruction",
        "snapshot": "prism-playwright",
        "timeout_sec": 1800,
        "memory": "8G",
        "cpus": 4,
        "network_enabled": true,
        "mcp_servers": {
          "playwright": {
            "command": "npx",
            "args": [
              "@playwright/mcp@latest",
              "--headless",
              "--browser",
              "chromium"
            ]
          }
        }
      }
    },
    "steps": ["play"]
  }
}
