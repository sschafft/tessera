# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
.next/
out/

# production builds
build/
dist/

# testing
coverage/
test-results/
playwright-report/
playwright/.cache/

# environment — .env.example is tracked as a template; everything else is local-only
.env
.env*.local

# vercel
.vercel/

# supabase (local stack — not used in dev, but present if a contributor opts in)
supabase/.branches/
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# tooling caches
.eslintcache
.cache/
.turbo/

# editors
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Claude Code agent state (per-session locks, transient task scratch)
.claude/

# misc
*.pem

# OS
.DS_Store
Thumbs.db

# Playwright MCP scratch dir
.playwright-mcp/
